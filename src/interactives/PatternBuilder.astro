---
---

<div class="interactive-wrap" id="pattern-builder">
  <div class="interactive-header">
    <h4 class="interactive-title">Try it: Align the zellige pattern</h4>
    <p class="interactive-subtitle">Every tile is in place but rotated wrong. Click each tile to rotate it until the pattern aligns. Zellige masters do this by eye across thousands of pieces.</p>
  </div>
  <div id="zpat-stage">
    <canvas id="zpat-canvas" width="600" height="600"></canvas>
    <div id="zpat-status">
      <span id="zpat-remaining">36 tiles remaining</span>
      <span id="zpat-timer">0:00</span>
    </div>
  </div>
  <div id="zpat-result" hidden>
    <p class="zpat-result-time" id="zpat-result-time"></p>
    <p class="zpat-result-text" id="zpat-result-text"></p>
    <button class="zpat-retry" id="zpat-retry">Try again</button>
  </div>
</div>

<style>
  #pattern-builder {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    margin: var(--space-8) 0;
  }

  #zpat-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  #zpat-canvas {
    display: block;
    width: 100%;
    max-width: 480px;
    height: auto;
    aspect-ratio: 1;
    cursor: pointer;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  #zpat-status {
    display: flex;
    justify-content: space-between;
    width: 100%;
    max-width: 480px;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  #zpat-timer {
    font-family: var(--font-heading);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  #zpat-result {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    animation: zpat-in 0.5s var(--ease-out);
  }

  #zpat-result[hidden] { display: none; }

  @keyframes zpat-in {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .zpat-result-time {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
  }

  .zpat-result-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    max-width: 50ch;
    line-height: 1.7;
  }

  .zpat-retry {
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    background: transparent;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .zpat-retry:hover { background: var(--color-surface-raised); }

  @media (max-width: 640px) {
    #pattern-builder { padding: var(--space-6); }
  }
</style>

<script>
  const cv = document.getElementById('zpat-canvas') as HTMLCanvasElement;
  const ctx = cv.getContext('2d')!;
  const remainEl = document.getElementById('zpat-remaining')!;
  const timerEl = document.getElementById('zpat-timer')!;
  const stageEl = document.getElementById('zpat-stage')!;
  const resultEl = document.getElementById('zpat-result')!;
  const resultTimeEl = document.getElementById('zpat-result-time')!;
  const resultTextEl = document.getElementById('zpat-result-text')!;

  // Zellige color palette
  const C = {
    bg: '#f8f4ed',
    blue: '#1e3a5f',
    teal: '#2a7a6d',
    terra: '#c85a3a',
    cream: '#e8dcc8',
    white: '#f5f0e1',
    gold: '#c89b3c',
    outline: '#8a7e6e',
  };

  // 6x6 grid of square tiles, each with a target rotation (0-3 = 0/90/180/270 deg)
  // Pattern: 8-pointed star motif repeating across the grid
  // Tile types: 0=star-center, 1=star-arm, 2=cross-fill, 3=border-piece
  const COLS = 6, ROWS = 6, TOTAL = COLS * ROWS;
  const PI2 = Math.PI / 2;

  interface Tile {
    type: number;    // shape type
    target: number;  // correct rotation (0-3)
    current: number; // current rotation (0-3)
    color: string;
    solved: boolean;
  }

  let tiles: Tile[] = [];
  let tStart = 0, tRunning = false, tFrame = 0, done = false;

  // Generate the pattern grid
  function generateTiles(): Tile[] {
    const t: Tile[] = [];
    const colors = [C.blue, C.teal, C.terra, C.gold, C.cream, C.white];

    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        // Create a repeating geometric motif
        const isCenter = (r % 3 === 1 && c % 3 === 1);
        const isArm = (r % 3 === 1 || c % 3 === 1) && !isCenter;
        const type = isCenter ? 0 : isArm ? 1 : 2;
        const target = ((r + c) * 7 + r * 3) % 4; // deterministic but varied
        const colorIdx = (r * COLS + c + r * 2) % colors.length;

        // Scramble: random rotation different from target
        let current = target;
        while (current === target) current = Math.floor(Math.random() * 4);

        t.push({
          type, target, current,
          color: colors[colorIdx],
          solved: false,
        });
      }
    }
    return t;
  }

  // Draw a single tile's geometric pattern
  function drawTilePattern(x: number, y: number, size: number, tile: Tile) {
    const s = size;
    const half = s / 2;

    ctx.save();
    ctx.translate(x + half, y + half);
    ctx.rotate(tile.current * PI2);

    // Clip to tile boundary
    ctx.beginPath();
    ctx.rect(-half, -half, s, s);
    ctx.clip();

    // Background
    ctx.fillStyle = tile.solved ? C.white : C.bg;
    ctx.fillRect(-half, -half, s, s);

    // Geometric pattern based on type
    ctx.fillStyle = tile.color;
    ctx.strokeStyle = C.outline;
    ctx.lineWidth = 1;

    if (tile.type === 0) {
      // Star center: 8-pointed star
      ctx.beginPath();
      for (let i = 0; i < 8; i++) {
        const a = (Math.PI / 4) * i - Math.PI / 8;
        const r1 = half * 0.85;
        const r2 = half * 0.45;
        const r = i % 2 === 0 ? r1 : r2;
        i === 0 ? ctx.moveTo(r * Math.cos(a), r * Math.sin(a))
                : ctx.lineTo(r * Math.cos(a), r * Math.sin(a));
      }
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
    } else if (tile.type === 1) {
      // Arm: directional arrow/chevron shape
      ctx.beginPath();
      ctx.moveTo(-half * 0.3, -half);
      ctx.lineTo(half * 0.3, -half);
      ctx.lineTo(half * 0.5, 0);
      ctx.lineTo(half * 0.3, half);
      ctx.lineTo(-half * 0.3, half);
      ctx.lineTo(-half * 0.1, 0);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
    } else {
      // Fill: diamond with internal cross
      const d = half * 0.65;
      ctx.beginPath();
      ctx.moveTo(0, -d);
      ctx.lineTo(d, 0);
      ctx.lineTo(0, d);
      ctx.lineTo(-d, 0);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
      // Inner cross
      ctx.beginPath();
      ctx.moveTo(0, -d * 0.4);
      ctx.lineTo(0, d * 0.4);
      ctx.moveTo(-d * 0.4, 0);
      ctx.lineTo(d * 0.4, 0);
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }

    ctx.restore();

    // Tile border
    ctx.strokeStyle = tile.solved ? C.teal : C.outline;
    ctx.lineWidth = tile.solved ? 1.5 : 0.5;
    ctx.strokeRect(x + 0.5, y + 0.5, s - 1, s - 1);
  }

  function draw() {
    const w = cv.getBoundingClientRect().width;
    const dpr = Math.min(devicePixelRatio || 1, 2);
    cv.width = w * dpr;
    cv.height = w * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const tileSize = w / COLS;

    // Background
    ctx.fillStyle = C.bg;
    ctx.fillRect(0, 0, w, w);

    // Draw tiles
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const tile = tiles[r * COLS + c];
        drawTilePattern(c * tileSize, r * tileSize, tileSize, tile);
      }
    }
  }

  function tileAt(clientX: number, clientY: number): number {
    const rect = cv.getBoundingClientRect();
    const x = clientX - rect.left;
    const y = clientY - rect.top;
    const tileSize = rect.width / COLS;
    const col = Math.floor(x / tileSize);
    const row = Math.floor(y / tileSize);
    if (col < 0 || col >= COLS || row < 0 || row >= ROWS) return -1;
    return row * COLS + col;
  }

  function checkSolved(tile: Tile): boolean {
    return tile.current % 4 === tile.target % 4;
  }

  function countRemaining(): number {
    return tiles.filter(t => !t.solved).length;
  }

  // Timer
  function fmtTime(ms: number): string {
    const s = Math.floor(ms / 1000);
    return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
  }

  function tickTimer() {
    if (!tRunning) return;
    timerEl.textContent = fmtTime(Date.now() - tStart);
    tFrame = requestAnimationFrame(tickTimer);
  }

  // Click handler
  cv.addEventListener('pointerdown', (e) => {
    if (done) return;
    const idx = tileAt(e.clientX, e.clientY);
    if (idx < 0 || tiles[idx].solved) return;

    // Start timer on first click
    if (!tRunning) {
      tRunning = true;
      tStart = Date.now();
      tickTimer();
    }

    // Rotate tile
    tiles[idx].current = (tiles[idx].current + 1) % 4;

    // Check if now correct
    if (checkSolved(tiles[idx])) {
      tiles[idx].solved = true;
    }

    const remaining = countRemaining();
    remainEl.textContent = remaining === 0
      ? 'Pattern complete'
      : `${remaining} tile${remaining === 1 ? '' : 's'} remaining`;

    draw();

    // Check win
    if (remaining === 0) {
      done = true;
      tRunning = false;
      cancelAnimationFrame(tFrame);
      const elapsed = Date.now() - tStart;
      timerEl.textContent = fmtTime(elapsed);

      setTimeout(() => {
        stageEl.style.display = 'none';
        resultTimeEl.textContent = `Completed in ${fmtTime(elapsed)}`;

        const secs = elapsed / 1000;
        if (secs < 30) {
          resultTextEl.textContent = 'Exceptional spatial reasoning. A zellige maalem (master) in Fez works at this speed across panels of ten thousand individually chiseled tiles, fitting each one by eye without guides or measurements.';
        } else if (secs < 60) {
          resultTextEl.textContent = 'Strong pattern recognition. Traditional zellige artisans train for eight or more years before they are trusted with commissioned work. The challenge is holding local tile alignment and global symmetry in mind simultaneously.';
        } else if (secs < 120) {
          resultTextEl.textContent = 'A solid attempt. The difficulty of zellige lies in the compound reasoning: each tile must fit its immediate neighbors while contributing to a pattern that only reveals itself at scale. Masters develop this dual awareness through years of repetition.';
        } else {
          resultTextEl.textContent = 'Every tile matters. Zellige craftsmen assemble their patterns face-down, only flipping the panel to reveal the result at the end. The spatial reasoning required to work blind from the back side is what separates masters from apprentices.';
        }

        resultEl.hidden = false;
      }, 600);
    }
  });

  // Retry
  document.getElementById('zpat-retry')!.addEventListener('click', () => {
    tiles = generateTiles();
    done = false;
    tRunning = false;
    cancelAnimationFrame(tFrame);
    timerEl.textContent = '0:00';
    remainEl.textContent = `${TOTAL} tiles remaining`;
    stageEl.style.display = '';
    resultEl.hidden = true;
    draw();
  });

  // Init
  tiles = generateTiles();
  draw();
</script>
