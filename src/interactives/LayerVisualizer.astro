  /* --- Buttons --- */
  .layer-buttons {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .layer-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-lg);
