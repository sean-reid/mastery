    .palette-selector { gap: var(--space-1); }
    .palette-btn { font-size: 0.65rem; padding: var(--space-1) var(--space-2); }
    .palette-swatch { width: 16px; height: 10px; }

    .layer-controls { gap: var(--space-6); }
    .layer-stat-number { font-size: var(--text-2xl); }

    .layer-buttons { gap: var(--space-2); }
    .layer-btn { padding: var(--space-2) var(--space-4); font-size: var(--text-xs); }
