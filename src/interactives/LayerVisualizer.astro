      0 0 40px rgba(192, 192, 192, 0.05);
  }

  #layer-canvas {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 1;
    border-radius: calc(var(--radius-lg) - 4px);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.5),
