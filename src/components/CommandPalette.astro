---
import type { RankedSkill } from '../types/skill';
import { CATEGORY_LABELS } from '../types/skill';

interface Props {
  skills: RankedSkill[];
}

const { skills } = Astro.props;

const searchData = skills.map((s) => ({
  id: s.slug,
  name: s.name,
  category: CATEGORY_LABELS[s.category],
  rank: s.rank,
  score: s.compositeScore,
  description: s.description.slice(0, 120),
}));
---

<div
  class="palette-backdrop"
  id="palette-backdrop"
  aria-hidden="true"
></div>

<div
  class="palette"
  id="command-palette"
  role="dialog"
  aria-modal="true"
  aria-label="Search skills"
  hidden
>
  <div class="palette-inner">
    <div class="palette-header">
      <svg class="palette-search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M11.5 11.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input
        type="text"
        class="palette-input"
        id="palette-input"
        placeholder="Search 100 skills..."
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="palette-esc">esc</kbd>
    </div>
    <ul class="palette-results" id="palette-results" role="listbox">
    </ul>
  </div>
</div>

<script type="application/json" id="palette-data" set:html={JSON.stringify(searchData)} />

<style>
  .palette-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 99;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .palette-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  .palette {
    position: fixed;
    top: 15vh;
    left: 50%;
    transform: translateX(-50%) scale(0.96);
    width: min(90vw, 560px);
    max-height: 60vh;
    z-index: 100;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }

  .palette[hidden] {
    display: flex;
  }

  .palette.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) scale(1);
  }

  .palette-inner {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .palette-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .palette-search-icon {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .palette-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 16px; /* Must be >= 16px to prevent iOS Safari auto-zoom on focus */
    font-family: var(--font-body);
    color: var(--color-text);
    min-width: 0;
  }

  .palette-input::placeholder {
    color: var(--color-text-muted);
  }

  .palette-esc {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .palette-esc { display: none; }
  }

  .palette-results {
    overflow-y: auto;
    max-height: calc(60vh - 56px);
    padding: var(--space-2);
  }

  .palette-results:empty {
    display: none;
  }

  @media (max-width: 640px) {
    .palette {
      top: 0;
      left: 0;
      transform: none;
      width: 100%;
      max-height: 100vh;
      border-radius: 0;
    }

    .palette.open {
      transform: none;
    }
  }
</style>

<script>
  import Fuse from 'fuse.js';

  interface SkillSearchItem {
    id: string;
    name: string;
    category: string;
    rank: number;
    score: number;
    description: string;
  }

  const dataEl = document.getElementById('palette-data');
  if (!dataEl) throw new Error('Missing palette data');

  const skills: SkillSearchItem[] = JSON.parse(dataEl.textContent || '[]');

  const fuse = new Fuse(skills, {
    keys: [
      { name: 'name', weight: 0.7 },
      { name: 'category', weight: 0.2 },
      { name: 'description', weight: 0.1 },
    ],
    threshold: 0.4,
    includeMatches: true,
    minMatchCharLength: 2,
  });

  const palette = document.getElementById('command-palette')!;
  const backdrop = document.getElementById('palette-backdrop')!;
  const input = document.getElementById('palette-input') as HTMLInputElement;
  const results = document.getElementById('palette-results')!;
  const trigger = document.getElementById('search-trigger');
  let activeIndex = -1;

  function open() {
    palette.removeAttribute('hidden');
    requestAnimationFrame(() => {
      palette.classList.add('open');
      backdrop.classList.add('open');
      input.focus();
    });
    document.body.style.overflow = 'hidden';
  }

  function close() {
    palette.classList.remove('open');
    backdrop.classList.remove('open');
    setTimeout(() => palette.setAttribute('hidden', ''), 200);
    input.value = '';
    results.innerHTML = '';
    activeIndex = -1;
    document.body.style.overflow = '';
    trigger?.focus();
  }

  function renderResults(items: SkillSearchItem[]) {
    activeIndex = -1;
    results.innerHTML = items
      .slice(0, 15)
      .map(
        (item, i) => `
        <li class="result-item" role="option" data-index="${i}" data-skill-id="${item.id}">
          <span class="result-rank">#${item.rank}</span>
          <span class="result-name">${item.name}</span>
          <span class="result-cat">${item.category}</span>
          <span class="result-score">${item.score}</span>
        </li>
      `
      )
      .join('');
  }

  function navigate(delta: number) {
    const items = results.querySelectorAll('.result-item');
    if (!items.length) return;
    items[activeIndex]?.classList.remove('highlighted');
    activeIndex = (activeIndex + delta + items.length) % items.length;
    items[activeIndex]?.classList.add('highlighted');
    items[activeIndex]?.scrollIntoView({ block: 'nearest' });
  }

  function jumpToSkill(skillId: string) {
    close();
    const el = document.getElementById(`skill-${skillId}`);
    if (!el) return;
    // Ensure the card is visible (may be deferred by infinite scroll)
    if (el.style.display === 'none' || el.dataset.deferred) {
      el.style.display = '';
      el.style.opacity = '1';
      el.style.transform = 'none';
      delete el.dataset.deferred;
    }
    // Scroll so the title sits just below the sticky nav
    const navHeight = document.querySelector('.sticky-nav')?.getBoundingClientRect().height || 60;
    const top = el.getBoundingClientRect().top + window.scrollY - navHeight - 16;
    window.scrollTo({ top, behavior: 'smooth' });
  }

  function selectActive() {
    const items = results.querySelectorAll('.result-item');
    const item = items[activeIndex] as HTMLElement | undefined;
    if (!item) return;
    const skillId = item.dataset.skillId;
    if (skillId) jumpToSkill(skillId);
  }

  // Event listeners
  input.addEventListener('input', () => {
    const query = input.value.trim();
    if (query.length < 2) {
      results.innerHTML = '';
      return;
    }
    const matches = fuse.search(query).map((r) => r.item);
    renderResults(matches);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      palette.classList.contains('open') ? close() : open();
    }
    if (e.key === '/' && !palette.classList.contains('open')) {
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag !== 'INPUT' && tag !== 'TEXTAREA') {
        e.preventDefault();
        open();
      }
    }
    if (e.key === 'Escape' && palette.classList.contains('open')) {
      close();
    }
  });

  palette.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); navigate(1); }
    if (e.key === 'ArrowUp') { e.preventDefault(); navigate(-1); }
    if (e.key === 'Enter') { e.preventDefault(); selectActive(); }
  });

  backdrop.addEventListener('click', close);
  trigger?.addEventListener('click', open);

  results.addEventListener('click', (e) => {
    const item = (e.target as HTMLElement).closest('.result-item') as HTMLElement;
    if (item?.dataset.skillId) jumpToSkill(item.dataset.skillId);
  });
</script>

<style is:global>
  .result-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: var(--text-sm);
    transition: background-color 80ms;
  }

  .result-item:hover,
  .result-item.highlighted {
    background: var(--color-surface-raised);
  }

  .result-rank {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    min-width: 2rem;
  }

  .result-name {
    font-weight: 500;
    color: var(--color-text);
    flex: 1;
  }

  .result-cat {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .result-score {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
  }
</style>
