---
interface Props {
  title: string;
  count: number;
}

const { title, count } = Astro.props;
---

<section class="category-divider">
  <div class="divider-content">
    <span class="divider-count">{count} skills</span>
    <h2 class="divider-title">{title}</h2>
  </div>
</section>

<style>
  .category-divider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--gutter);
    margin: var(--space-12) 0;
    background: var(--color-surface-raised);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .divider-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .divider-count {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .divider-title {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text);
  }
</style>
